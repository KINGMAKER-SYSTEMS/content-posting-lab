# ── Required for video generation ─────────────────────────────────────
# At least one provider key is needed to generate videos.
XAI_API_KEY=              # Grok video generation
FAL_KEY=                  # FAL providers (Wan, Kling, Ovi)
LUMA_API_KEY=             # Luma Dream Machine
REPLICATE_API_TOKEN=      # Replicate providers (MiniMax, Wan, Kling)
OPENAI_API_KEY=           # Sora 2 video generation AND GPT-4.1 caption OCR

# ── Optional ──────────────────────────────────────────────────────────
POSTIZ_API_KEY=           # Postiz social media scheduling
POSTIZ_BASE_URL=          # Postiz API base URL (default: https://app.postiz.com)

# ── Google Drive ─────────────────────────────────────────────────────
# Service account for Drive API. Use ONE of these:
GOOGLE_SERVICE_ACCOUNT_FILE=  # Local: path to JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=  # Railway: base64-encoded JSON key

# ── Cloudflare Email Routing ──────────────────────────────────────────
CF_API_TOKEN=             # CF API token with Email Routing permissions
CF_ZONE_ID=               # Zone ID for your email domain
CF_ACCOUNT_ID=            # Cloudflare account ID
CF_EMAIL_DOMAIN=          # Domain for email aliases (e.g. yourdomain.com)

# ── Railway deployment ────────────────────────────────────────────────
# PORT is set automatically by Railway. Locally defaults to 8000.
# PORT=8000

# ── CORS (optional, comma-separated origins) ─────────────────────────
# Only needed if frontend is served from a different domain.
# CORS_ORIGINS=https://your-app.railway.app
